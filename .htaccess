# CMS setup secret — change this to something long and random before first use
SetEnv CMS_SETUP_SECRET thisisthesecretcodeforjeiws2022

# Prevent directory listing
Options -Indexes

# ETags based on modification time + size so the server can tell browsers
# exactly when a file has changed
FileETag MTime Size

<IfModule mod_headers.c>
    # HTML — never serve from cache; always fetch fresh from server.
    # This ensures mobile browsers always get the latest version strings.
    <FilesMatch "\.html$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # CSS and JS — browsers must revalidate on every request.
    # Version query strings (?v=N) act as hard cache-busters when files change.
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Images, fonts, favicons — safe to cache for a long time
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# Gzip compression for faster delivery
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json application/ld+json text/xml
</IfModule>

# Security headers (trust signals for Google)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Block direct hotlinking of project images from outside the domain
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?jeiws\.com [NC]
    RewriteCond %{HTTP_REFERER} !^https?://localhost [NC]
    RewriteRule ^assets/project-images/.*\.(jpg|jpeg|png|webp)$ - [F,NC,L]
</IfModule>

# Canonical trailing-slash redirect (avoid duplicate content)
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Redirect index.html to root (avoid duplicate pages)
    RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
    RewriteRule ^index\.html$ / [R=301,L]
</IfModule>
