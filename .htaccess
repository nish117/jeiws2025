# Prevent directory listing
Options -Indexes

# ETags based on modification time + size so the server can tell browsers
# exactly when a file has changed
FileETag MTime Size

<IfModule mod_headers.c>
    # CSS and JS — browsers must revalidate on every request.
    # If the file is unchanged the server returns 304 (no re-download).
    # If the file changed it returns 200 with the new content automatically.
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Images, fonts, favicons — safe to cache for a long time
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# Gzip compression for faster delivery
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json
</IfModule>
